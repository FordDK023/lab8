<%- include('partials/header.ejs') %>
<%- include('partials/navbar.ejs') %>

<div class="container py-4">
    <div class="top-title">
        <div>
            <h2>Product Stock List</h2>
            <p>รายการสินค้าในคลังซูเปอร์มาร์เก็ต</p>
        </div>

        
    </div>

    <div class="stock-table-box">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Product Image</th>
                    <th>Product Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Status</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>

            <tbody>
                <% if (products.length > 0) { %>
                    <% products.forEach((product) => { %>
                        <tr>
                            <td><%= product.id %></td>

                            <td>
                                <img src="/assets/img/<%= product.image %>" class="table-img">
                            </td>

                            <td class="fw-bold"><%= product.name %></td>
                            <td><%= product.category %></td>
                            <td><%= Number(product.price).toFixed(2) %> Baht</td>
                            <td><%= product.stock %></td>

                            <td>
                                <% if (product.stock == 0) { %>
                                    <span class="badge-stock badge-out">Out of Stock</span>
                                <% } else { %>
                                    <span class="badge-stock badge-in">Available</span>
                                <% } %>
                            </td>

                            <td class="text-center">
                                <a href="/product/edit/<%= product.id %>" class="btn btn-sm btn-edit">Edit</a>
                                <a 
                                    href="/product/delete/<%= product.id %>" 
                                    onclick="return confirm('Are you sure you want to delete this product?');"
                                    class="btn btn-sm btn-delete"
                                >
                                    Delete
                                </a>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="8" class="text-center py-5 text-muted">
                            No products found
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<%- include('partials/footer.ejs') %>